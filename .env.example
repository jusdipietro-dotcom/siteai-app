# =============================================================
#  SiteAI — Variables de entorno
#  Copiá este archivo a .env.local (dev) o configuralas en
#  tu plataforma de deploy (Vercel / Railway / VPS).
# =============================================================

# ─── Base de datos (PostgreSQL) ────────────────────────────────
# Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Railway: postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#
# URL principal (puede ser un pooler como PgBouncer en Neon/Supabase):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# URL directa (sin pooler) — requerida solo si DATABASE_URL usa un pooler.
# En Railway puedes usar la misma URL para ambas.
# En Neon: usa la "Direct connection URL" del dashboard.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"


# ─── NextAuth ─────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIA_ESTO_openssl_rand_-base64_32"

# URL pública de la app (sin trailing slash)
# Desarrollo: http://localhost:3000
# Producción: https://tudominio.com
NEXTAUTH_URL="https://tudominio.com"


# ─── Google OAuth (opcional) ──────────────────────────────────
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://tudominio.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""


# ─── MercadoPago ─────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel/app
# Usar el Access Token de PRODUCCIÓN (empieza con APP_USR-)
MP_ACCESS_TOKEN="APP_USR-XXXXXXXXXXXXXXXX"


# ─── URL pública de la app ────────────────────────────────────
# Usado para construir back_url en pagos MP y links de sitios publicados.
# Debe coincidir con NEXTAUTH_URL.
NEXT_PUBLIC_APP_URL="https://tudominio.com"
